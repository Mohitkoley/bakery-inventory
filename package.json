{
	"name": "bakery-inventory",
	"version": "1.0.0",
	"description": "Bakery Inventory Management System - Offline-first with SQLite + Supabase sync",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:prod": "vite build && electrobun build",
		"clean": "rm -rf node_modules && rm -rf dist && rm -rf artifacts && rm -rf build"
	},
	"dependencies": {
		"sql.js": "^1.11.0",
		"@supabase/supabase-js": "^2.47.0",
		"electrobun": "1.16.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router-dom": "^6.28.0",
		"lucide-react": "^0.460.0",
		"date-fns": "^4.1.0",
		"recharts": "^2.13.3",
		"zustand": "^5.0.1"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}